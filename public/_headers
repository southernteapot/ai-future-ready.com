# Headers for Cloudflare Workers static assets.
# These apply ONLY to files served from the asset layer (this public/ dir).
# Worker-rendered responses (HTML pages, /api/v1 dynamic routes) get their
# headers from next.config.ts headers() — keep the two in sync.
# Docs: https://developers.cloudflare.com/workers/static-assets/headers/

/content/*
  X-Robots-Tag: noindex, follow
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/api/*
  X-Robots-Tag: noindex, follow
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

